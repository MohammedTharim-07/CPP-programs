#include<iostream>
using namespace std;
void calculator(int a,int b)
{
    cout<<"sum="<<a+b<<endl;
}
void calculator(int c,double d)
{
    cout<<"float add:"<<c+d<<endl;
}
void calculator(int a,int b,int c)
{
    cout<<"operator total:"<<a-b*c<<endl;
}
int main()
{
    calculator(10,20);
    calculator(10,20.5);
    calculator(10,2,4);
}
